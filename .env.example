# 环境变量配置文件示例

# 数据库配置 (Docker部署使用postgres，本地开发可用sqlite)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/etf

# JWT配置
JWT_SECRET=replace_with_a_long_random_secret

# CORS配置 (JSON数组)
CORS_ORIGINS=["http://localhost:8123","http://127.0.0.1:8123"]

# Redis配置
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# LLM提供商: openai / deepseek / ollama / gemini / qwen
LLM_PROVIDER=deepseek

# DeepSeek配置 (推荐)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Gemini配置
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLE_GROUNDING=true

# 通义千问配置
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_ENABLE_SEARCH=true

# Ollama配置 (本地)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Bark推送配置
BARK_KEY=your_bark_key
BARK_URL=https://api.day.app
